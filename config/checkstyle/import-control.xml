<?xml version="1.0"?>
<!DOCTYPE import-control PUBLIC
    "-//Checkstyle//DTD ImportControl Configuration 1.4//EN"
    "https://checkstyle.org/dtds/import_control_1_4.dtd">
<import-control pkg="com.nextdv">

  <!-- domain: 프레임워크 및 다른 레이어 import 금지 -->
  <subpackage name="domain">
    <allow pkg="java"/>
    <disallow pkg="com.nextdv.api"/>
    <disallow pkg="com.nextdv.infrastructure"/>
    <disallow pkg="org.springframework"/>
    <disallow pkg="jakarta"/>
  </subpackage>

  <!-- infrastructure: domain import 허용, api import 금지 -->
  <subpackage name="infrastructure">
    <allow pkg="java"/>
    <allow pkg="com.nextdv.domain"/>
    <allow pkg="jakarta"/>
    <allow pkg="org.springframework"/>
    <allow pkg="org.postgresql"/>
    <disallow pkg="com.nextdv.api"/>
  </subpackage>

  <!-- api: domain, infrastructure import 허용 -->
  <subpackage name="api">
    <allow pkg="java"/>
    <allow pkg="com.nextdv.domain"/>
    <allow pkg="com.nextdv.infrastructure"/>
    <allow pkg="jakarta"/>
    <allow pkg="org.springframework"/>
    <allow pkg="io.swagger"/>
    <allow pkg="org.springdoc"/>
  </subpackage>

</import-control>
